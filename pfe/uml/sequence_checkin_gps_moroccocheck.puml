@startuml
!theme plain
skinparam backgroundColor #FFFFFF
skinparam defaultFontName Arial
skinparam defaultFontSize 12
skinparam roundCorner 8
skinparam shadowing false
skinparam ArrowColor #2C3E50
skinparam BorderColor #2C3E50
skinparam sequence {
  ParticipantBackgroundColor #FFFFFF
  ActorBackgroundColor #2980B9
  LifeLineBorderColor #2C3E50
}

title MoroccoCheck — Séquence : check-in GPS (validation Haversine)

actor "Utilisateur\n(contributeur / touriste)" as U #2980B9
participant "Application\nFlutter" as APP #2980B9
participant "Service GPS\n(géolocalisation)" as GPS #95A5A6
participant "API REST\n(Node / Express)" as API #2C3E50
participant "Logique\ngamification" as GAM #8E44AD
database "MySQL" as DB #F39C12

U -> APP : Appuie sur « Check-in »
activate APP

APP -> GPS : getCurrentPosition()
activate GPS
GPS --> APP : latitude, longitude,\nprécision (accuracy)
deactivate GPS

alt Précision GPS insuffisante\n(accuracy > seuil métier)
  APP --> U : Message : signal GPS faible,\nréessayer à découvert
  deactivate APP
else Position exploitable
  APP -> API : POST /api/checkins\nAuthorization: Bearer JWT\n+ { siteId, lat, lon, accuracy, ... }
  activate API

  API -> API : Middleware JWT\n(vérification session)

  alt Jeton absent / invalide / expiré
    API --> APP : 401 Unauthorized
    APP --> U : Session expirée — reconnecter
    deactivate API
    deactivate APP
  else Authentification OK
    API -> DB : SELECT coordonnées\nsite (lat, lon), règles rayon
    activate DB
    DB --> API : TouristSite
    deactivate DB

    API -> API : haversineDistance(\nposition user, position site)

    alt Hors zone\n(distance > rayon autorisé)
      API --> APP : 4xx\n{ validation échouée, distance }
      APP --> U : Check-in refusé\n(hors périmètre)
    else Dans la zone
      API -> API : Vérifier précision,\ndurée minimale de visite,\nanti-fraude (règles métier)

      alt Règles non satisfaites
        API --> APP : 4xx\n{ motif : précision / durée }
        APP --> U : Validation partielle ou refus
      else Check-in validé
        API -> DB : INSERT check-in\n(statut APPROVED / enregistrement)
        activate DB
        DB --> API : id check-in
        deactivate DB

        API -> GAM : awardPoints(\nCHECKIN, options photo)
        activate GAM
        GAM -> DB : UPDATE users\n(points, checkins_count, …)
        GAM -> DB : UPDATE tourist_sites\n(last_verified_at, …)
        GAM -> GAM : updateRank()\n(seuils BRONZE / SILVER / …)
        DB --> GAM : OK
        deactivate GAM

        API --> APP : 200 OK\n{ status, distanceMeters,\npoints, badge? }
        deactivate API

        APP --> U : Confirmation + points gagnés
      end
    end
  end
end

deactivate APP

@enduml
