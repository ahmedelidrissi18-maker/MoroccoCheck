@startuml
!theme plain
skinparam backgroundColor #FFFFFF
skinparam defaultFontName Arial
skinparam defaultFontSize 12
skinparam roundCorner 8
skinparam shadowing false
skinparam ArrowColor #2C3E50
skinparam BorderColor #2C3E50
skinparam activity {
  BackgroundColor #FFFFFF
  BorderColor #2C3E50
  DiamondBackgroundColor #ECF0F1
}

title MoroccoCheck — Activité : traitement de la gamification

start

:Action utilisateur déclenchante\n(check-in GPS, publication d'avis,\nupload photo, etc.);

:Identifier le **type d'action**;

:Récupérer le **barème de points**\nassocié à cette action;

:Mettre à jour le solde\n**UPDATE users.points**\n(points ← points + Δ);

partition "Évaluation du rang" {
  :Calculer le **nouveau rang** selon\nle total de points :
  ----
  **< 500** → BRONZE
  **500 à 1999** → SILVER
  **2000 à 4999** → GOLD
  **≥ 5000** → PLATINUM;

  if (Le rang obtenu est **différent**\ndu rang stocké en base ?) then (oui)
    :**UPDATE** le champ **rank**\nde l'utilisateur;
    :**Notifier** l'utilisateur\n(changement de rang);
  else (non)
    :Conserver le rang actuel;
  endif
}

partition "Attribution des badges" {
  :Parcourir les règles de **badges**\n(critères sur points, actions, etc.);

  if (Au moins un **nouveau badge**\néligible et non encore obtenu ?) then (oui)
    :**INSERT** dans **user_badges**\n(badge_id, user_id, date);
    :**Notifier** l'obtention du badge;
  else (non)
    :Aucun badge supplémentaire;
  endif
}

stop

@enduml
