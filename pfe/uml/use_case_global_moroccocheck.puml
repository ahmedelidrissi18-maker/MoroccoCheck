@startuml
!theme plain
skinparam backgroundColor #FFFFFF
skinparam defaultFontName Arial
skinparam defaultFontSize 12
skinparam roundCorner 8
skinparam shadowing false
skinparam ArrowColor #2C3E50
skinparam BorderColor #2C3E50
skinparam usecase {
  BackgroundColor #FFFFFF
  BorderColor #2C3E50
}
skinparam actor {
  BorderColor #2C3E50
}

title MoroccoCheck — Cas d'utilisation globaux

left to right direction

actor "Touriste\n<< TOURIST >>" as ACT_TOURIST #27AE60
actor "Contributeur\n<< CONTRIBUTOR >>" as ACT_CONTRIB #2980B9
actor "Professionnel\n<< PROFESSIONAL >>" as ACT_PRO #8E44AD
actor "Administrateur\n<< ADMIN >>" as ACT_ADMIN #E74C3C

ACT_CONTRIB -|> ACT_TOURIST

rectangle "MoroccoCheck Platform" #FFFFFF {
  usecase "S'inscrire" as UC_REGISTER
  usecase "S'authentifier" as UC_LOGIN
  usecase "Consulter le catalogue\nde sites" as UC_LIST
  usecase "Consulter le détail\nd'un site" as UC_DETAIL
  usecase "Afficher la carte\ndes sites" as UC_MAP
  usecase "Obtenir la position GPS" as UC_GPS
  usecase "Effectuer un check-in GPS" as UC_CHECKIN
  usecase "Publier un avis" as UC_REVIEW
  usecase "Joindre des photos\nà l'avis" as UC_REVIEW_PHOTO
  usecase "Consulter badges\net classement" as UC_GAMIFY
  usecase "Gérer son profil" as UC_PROFILE
  usecase "Demander le passage\nau statut contributeur" as UC_REQ_CONTRIB
  usecase "Contribuer du contenu\nenrichi (photos, retours)" as UC_ENRICH

  usecase "Créer ou modifier\nune fiche site" as UC_SITE_CRUD
  usecase "Revendiquer un site" as UC_CLAIM
  usecase "Répondre aux avis\nvisiteurs" as UC_OWNER_REPLY
  usecase "Consulter l'espace\nprofessionnel" as UC_PRO_HUB

  usecase "Modérer les fiches sites" as UC_MOD_SITES
  usecase "Modérer les avis" as UC_MOD_REVIEWS
  usecase "Gérer les utilisateurs" as UC_MOD_USERS
  usecase "Consulter les statistiques\nglobales" as UC_STATS
  usecase "Traiter les demandes\ncontributeur" as UC_MOD_REQ
}

ACT_TOURIST --> UC_REGISTER
ACT_TOURIST --> UC_LOGIN
ACT_TOURIST --> UC_LIST
ACT_TOURIST --> UC_DETAIL
ACT_TOURIST --> UC_MAP
ACT_TOURIST --> UC_CHECKIN
ACT_TOURIST --> UC_REVIEW
ACT_TOURIST --> UC_GAMIFY
ACT_TOURIST --> UC_PROFILE
ACT_TOURIST --> UC_REQ_CONTRIB

ACT_CONTRIB --> UC_ENRICH

ACT_PRO --> UC_SITE_CRUD
ACT_PRO --> UC_CLAIM
ACT_PRO --> UC_OWNER_REPLY
ACT_PRO --> UC_PRO_HUB

ACT_ADMIN --> UC_MOD_SITES
ACT_ADMIN --> UC_MOD_REVIEWS
ACT_ADMIN --> UC_MOD_USERS
ACT_ADMIN --> UC_STATS
ACT_ADMIN --> UC_MOD_REQ

UC_CHECKIN ..> UC_GPS : <<include>>
UC_CHECKIN ..> UC_LOGIN : <<include>>
UC_REVIEW ..> UC_LOGIN : <<include>>
UC_ENRICH ..> UC_LOGIN : <<include>>
UC_SITE_CRUD ..> UC_LOGIN : <<include>>
UC_CLAIM ..> UC_LOGIN : <<include>>
UC_OWNER_REPLY ..> UC_LOGIN : <<include>>
UC_PRO_HUB ..> UC_LOGIN : <<include>>
UC_MOD_SITES ..> UC_LOGIN : <<include>>
UC_MOD_REVIEWS ..> UC_LOGIN : <<include>>
UC_MOD_USERS ..> UC_LOGIN : <<include>>
UC_STATS ..> UC_LOGIN : <<include>>
UC_MOD_REQ ..> UC_LOGIN : <<include>>

UC_REVIEW_PHOTO <.. UC_REVIEW : <<extend>>

@enduml
