@startuml
!theme plain
skinparam backgroundColor #FFFFFF
skinparam defaultFontName Arial
skinparam defaultFontSize 12
skinparam roundCorner 8
skinparam shadowing false
skinparam ArrowColor #2C3E50
skinparam BorderColor #2C3E50
skinparam sequence {
  ParticipantBackgroundColor #FFFFFF
  ActorBackgroundColor #27AE60
  LifeLineBorderColor #2C3E50
}

title MoroccoCheck — Séquence : authentification (login)

actor "Utilisateur" as U #27AE60
participant "Application\nFlutter" as APP #2980B9
participant "API REST\n(Node / Express)" as API #2C3E50
database "MySQL" as DB #F39C12

U -> APP : Saisit email et mot de passe\npuis valide le formulaire
activate APP

APP -> API : POST /api/auth/login\nJSON { email, password }
activate API

API -> API : Validation des entrées\n(Joi / express-validator)

alt Données invalides (format)
  API --> APP : 400 Bad Request\n{ success: false, message }
  APP --> U : Affiche erreur de saisie
else Données valides
  API -> DB : SELECT user\nWHERE email = ?
  activate DB
  DB --> API : Ligne utilisateur ou vide
  deactivate DB

  alt Utilisateur introuvable
    API --> APP : 401 Unauthorized\n(invalid credentials)
    APP --> U : Message d'échec de connexion
  else Utilisateur trouvé
    API -> API : bcrypt.compare(\nmot de passe, password_hash)

    alt Mot de passe incorrect
      API --> APP : 401 Unauthorized
      APP --> U : Identifiants incorrects
    else Mot de passe correct
      API -> API : jwt.sign(access_token)\n+ génération refresh token
      API -> DB : INSERT / UPDATE session\n(access_token, refresh, expires_at)
      activate DB
      DB --> API : OK
      deactivate DB

      API --> APP : 200 OK\n{ accessToken, refreshToken, user }
      deactivate API

      APP -> APP : Stockage sécurisé\ndes jetons (secure storage)
      APP --> U : Redirection vers l'écran\nprincipal (Dashboard / Home)
    end
  end
end

deactivate APP

@enduml
