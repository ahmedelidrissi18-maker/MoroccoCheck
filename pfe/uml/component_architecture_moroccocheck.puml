@startuml
!theme plain
skinparam backgroundColor #FFFFFF
skinparam defaultFontName Arial
skinparam defaultFontSize 11
skinparam roundCorner 8
skinparam shadowing false
skinparam ArrowColor #2C3E50
skinparam BorderColor #2C3E50
skinparam component {
  BackgroundColor #FFFFFF
  BorderColor #2C3E50
}
skinparam package {
  BackgroundColor #FAFAFA
  BorderColor #2C3E50
}

title MoroccoCheck — Diagramme de composants (architecture logicielle)

package "Couche présentation" #FFFFFF {
  component "Application mobile\nFlutter / Dart" as FLUTTER #2980B9
  component "Interface d'administration\nReact / Vite" as ADMIN_WEB #8E44AD
}

package "Couche logique métier (API)" #FFFFFF {
  component "Routes Express" as ROUTES #2C3E50
  component "Contrôleurs" as CTRL #2C3E50
  component "Services métier" as SVC #2C3E50
  component "Utilitaires GPS\n(Haversine, rayon)" as GPS_UTIL #2C3E50
  component "Gamification\n(points, badges, rangs)" as GAM #8E44AD
  component "Validation schémas\n(Joi / express-validator)" as JOI #2C3E50
  component "Middleware\n(auth JWT, erreurs, rate limit)" as MW #2C3E50
}

package "Couche données" #FFFFFF {
  database "MySQL 8.x" as MYSQL #F39C12
  note right of MYSQL
    Tables relationnelles
    **Vues** (stats agrégées)
    **Triggers** (compteurs, notes)
  end note
}

cloud "Services externes" #F5F5F5 {
  component "Firebase\n(Auth / config mobile)" as FB #95A5A6
  component "Google OAuth\n(Sign-In)" as GOOGLE_OAUTH #95A5A6
  component "Fournisseur de cartes\n(ex. tuiles / API carto)" as MAP_API #95A5A6
  component "GitHub Actions\n(CI : tests, build)" as GHA #95A5A6
}

FLUTTER -down-> ROUTES : **HTTPS / REST**\n(JSON)
ADMIN_WEB -down-> ROUTES : **HTTPS / REST**\n(JSON)

ROUTES -down-> MW
MW -down-> CTRL
CTRL -down-> SVC
CTRL ..> JOI : validation\nentrées
SVC ..> GPS_UTIL : contrôle\ndistances
SVC ..> GAM : points,\nbadges, classement

SVC -down-> MYSQL : **mysql2**\n(SQL / transactions)

FLUTTER ..> FB : SDK Firebase
FLUTTER ..> GOOGLE_OAUTH : **OAuth 2.0**\n(idToken)
FLUTTER ..> MAP_API : affichage carte\n(tuiles / géoloc.)

GHA ..> ROUTES : **CI/CD**\n(build, tests,\nanalyse statique)

note bottom of FLUTTER
  Utilisateurs : touristes,
  contributeurs, professionnels
end note

note bottom of ADMIN_WEB
  Rôle **ADMIN** :
  modération, stats
end note

@enduml
