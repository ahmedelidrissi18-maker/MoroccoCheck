@startuml use_case_contributeur
!define CONTRIBUTOR_COLOR #E74C3C
!define PRIMARY_COLOR #2ECC71
!define GOLD_COLOR #F39C12

skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam shadowing false
skinparam defaultFontName Arial

skinparam actor {
    BackgroundColor CONTRIBUTOR_COLOR
    BorderColor #2C3E50
}

skinparam usecase {
    BackgroundColor #FFFFFF
    BorderColor #2C3E50
    ArrowColor #2C3E50
}

left to right direction

actor "🔴 Contributeur" as Contributeur #E74C3C
actor "👤 Touriste" as Touriste #4A90E2

rectangle "Système MoroccoCheck" {
    
    package "Module Authentification" #F8F9FA {
        usecase "CU01\nS'inscrire" as CU01
        usecase "CU02\nSe connecter" as CU02
        usecase "CU04\nModifier le profil\nutilisateur" as CU04
    }
    
    package "Module Contribution" #FFEBEE {
        usecase "CU10\nEffectuer un\ncheck-in GPS" as CU10 #E74C3C
        usecase "CU11\nLaisser un avis\nsur un site" as CU11 #E74C3C
        usecase "CU12\nAjouter une photo" as CU12
    }
    
    package "Module Gamification" #FFF9C4 {
        usecase "CU14\nConsulter son profil\net statistiques" as CU14
        usecase "CU15\nVoir ses badges\nobtenus" as CU15
        usecase "CU16\nConsulter le\nleaderboard" as CU16
        usecase "CU17\nGagner des points" as CU17 #F39C12
    }
}

actor "🗺️ Google Maps API" as GoogleMaps #4A90E2
actor "🔔 Firebase FCM" as Firebase #FFA726

' Héritage
Contributeur -up-|> Touriste

' Relations Contributeur
Contributeur --> CU01
Contributeur --> CU02
Contributeur --> CU04
Contributeur --> CU10
Contributeur --> CU11
Contributeur --> CU12
Contributeur --> CU14
Contributeur --> CU15
Contributeur --> CU16

' Relations include/extend
CU10 ..> CU17 : <<include>>
CU11 ..> CU17 : <<include>>
CU12 .> CU10 : <<extend>>
CU12 .> CU11 : <<extend>>

' Relations avec systèmes externes
CU10 ..> GoogleMaps : <<use>>\nValidation GPS\n(rayon 100m)
CU17 ..> Firebase : <<use>>

note right of Contributeur
  **Type:** Utilisateur actif authentifié
  **Hérite de:** Touriste
  
  **Système de points:**
  • Check-in: 10 pts (+5 avec photo)
  • Avis: 20 pts
  
  **Niveaux:**
  🥉 Bronze (0 pts)
  🥈 Argent (100 pts)
  🥇 Or (500 pts)
  💎 Platine (1000 pts)
end note

note bottom of CU17
  **Badges disponibles:**
  🗺️ Explorateur
  📍 Guide
  ⭐ Expert
  📸 Photographe
  ✍️ Critique
  👑 Influenceur
end note

@enduml
